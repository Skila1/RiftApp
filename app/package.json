{
  "name": "riftapp-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-main/main.js",
  "scripts": {
    "compile": "tsc",
    "icons": "node scripts/prepare-icons.cjs",
    "dev": "npm run compile && concurrently -k -n tsc,vite,electron \"tsc -w --preserveWatchOutput\" \"npm run dev:frontend\" \"wait-on http-get://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:frontend": "cd ../frontend && npm run dev",
    "start": "npm run compile && cross-env NODE_ENV=development electron .",
    "prebuild": "npm run compile && npm run icons",
    "build": "electron-builder",
    "pack": "npm run compile && npm run icons && electron-builder --dir",
    "dist:win": "npm run compile && npm run icons && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "build": {
    "appId": "io.riftapp.desktop",
    "productName": "Rift",
    "executableName": "Rift",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist-main/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName} Setup ${version}.${ext}",
      "signAndEditExecutable": false,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Rift",
      "uninstallDisplayName": "Rift",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh",
      "warningsAsErrors": false
    },
    "afterPack": "./scripts/afterPack.cjs",
    "publish": null
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0",
    "rcedit": "^5.0.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "author": "RiftApp",
  "description": "Rift desktop"
}
