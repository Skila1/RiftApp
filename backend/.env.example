# Postgres
POSTGRES_DB=riftapp
POSTGRES_USER=riftapp
POSTGRES_PASSWORD=riftapp_dev

# MinIO / S3
S3_ACCESS_KEY=riftapp
S3_SECRET_KEY=riftapp_dev
S3_BUCKET=riftapp
S3_PUBLIC_URL=/s3

# Auth
JWT_SECRET=<run: openssl rand -hex 32>
ALLOWED_ORIGINS=https://riftapp.io,https://www.riftapp.io

# LiveKit
LIVEKIT_URL=wss://livekit.riftapp.io
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
