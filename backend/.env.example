# Copy to .env and replace every placeholder. Do not commit real secrets.

# --- Postgres (local Docker Compose uses internal URL; Neon in production) ---
POSTGRES_DB=riftapp
POSTGRES_USER=riftapp
POSTGRES_PASSWORD=<generate-strong-password>
# For Neon: pooled URL for the app, sslmode=require (see Neon dashboard)
DATABASE_URL=postgres://USER:PASSWORD@ep-XXXX.region.aws.neon.tech/neondb?sslmode=require

# --- Redis (local: redis://redis:6379 in Compose; Redis Cloud: rediss://...) ---
REDIS_URL=rediss://default:<password>@<host>:<port>

# --- S3-compatible object storage (Cloudflare R2) ---
# R2 endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY=<r2-api-token-access-key-id>
S3_SECRET_KEY=<r2-api-token-secret-access-key>
S3_BUCKET=<bucket-name>
# Required for R2 with many S3 clients:
S3_REGION=auto
# Pre-created bucket on R2: false. Local dev emulators that auto-create: true
S3_MANAGE_BUCKET=false
# Legacy; stored attachment URLs are relative — leave empty unless you know you need it
S3_PUBLIC_URL=

# --- Auth / HTTP ---
JWT_SECRET=<run: openssl rand -hex 32>
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- LiveKit ---
LIVEKIT_URL=wss://livekit.<your-domain>
LIVEKIT_API_KEY=<generate>
LIVEKIT_API_SECRET=<generate>

# --- API ---
PORT=8080
# Optional: production safety checks
# ENV=production
