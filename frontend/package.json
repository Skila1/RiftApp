{
  "name": "riftapp-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "build:mobile": "npx cross-env VITE_CAPACITOR=1 npm run build && npx cap sync",
    "build:ios": "npx cross-env VITE_CAPACITOR=1 npm run build && npx cap sync ios && npx cap open ios",
    "build:android": "npx cross-env VITE_CAPACITOR=1 npm run build && npx cap sync android && npx cap open android",
    "icons:generate": "npx @capacitor/assets generate --iconBackgroundColor #111214 --splashBackgroundColor #111214"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@livekit/track-processors": "^0.7.2",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "livekit-client": "^2.18.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.7",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.13",
    "@rollup/rollup-win32-x64-msvc": "^4.34.9"
  }
}
